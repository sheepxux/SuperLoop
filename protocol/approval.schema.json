{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sheepxux/Loop-Engineering/v1.1.0/protocol/approval.schema.json",
  "title": "Strategy Promotion Approval",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "loop", "experimentId", "experimentSha256", "baselineVersion", "approver", "approvedAt", "reason"],
  "properties": {
    "apiVersion": { "type": "string", "const": "loop-engineering/v1" },
    "loop": { "type": "string", "minLength": 1 },
    "experimentId": { "type": "string", "minLength": 3 },
    "experimentSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "baselineVersion": { "type": "integer", "minimum": 1 },
    "approver": { "type": "string", "minLength": 1, "pattern": "\\S" },
    "approvedAt": { "type": "string", "minLength": 20 },
    "reason": { "type": "string", "minLength": 3, "pattern": "\\S" }
  }
}
