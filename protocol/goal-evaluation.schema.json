{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sheepxux/Loop-Engineering/v1.1.0/protocol/goal-evaluation.schema.json",
  "title": "Loop Goal Evaluation",
  "description": "Independent final evaluation of a finite WorkPlan against the complete Loop goal.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "loop",
    "basisSha256",
    "evaluator",
    "verdict",
    "criteria",
    "evidence",
    "reasons",
    "affectedParts",
    "nextAction"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "loop-engineering/v1"
    },
    "loop": {
      "type": "string",
      "minLength": 1
    },
    "basisSha256": {
      "description": "Digest of the exact contract, part definitions, passed states, and artifact bindings evaluated as one goal-completion basis.",
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "evaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "contextId", "evaluatedAt"],
      "properties": {
        "identity": { "type": "string", "minLength": 1 },
        "contextId": { "type": "string", "minLength": 1 },
        "evaluatedAt": { "type": "string", "minLength": 20 }
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail", "blocked", "needs-human"]
    },
    "criteria": {
      "description": "One record for every exact string in loop.goal.acceptanceCriteria.",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["statement", "verdict", "summary"],
        "properties": {
          "statement": { "type": "string", "minLength": 3 },
          "verdict": {
            "type": "string",
            "enum": ["pass", "fail"]
          },
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "summary"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "command": { "type": "string", "minLength": 1 },
          "exitCode": { "type": ["integer", "null"] }
        }
      }
    },
    "reasons": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "affectedParts": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "nextAction": {
      "type": "string",
      "enum": ["complete", "retry", "resume-parts", "ask-human"]
    }
  }
}
