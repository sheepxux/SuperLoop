{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sheepxux/Loop-Engineering/v1.1.0/protocol/state.schema.json",
  "title": "Loop State",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "loop", "lastRunAt", "items", "budgets"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "loop-engineering/v1"
    },
    "loop": {
      "type": "string"
    },
    "generation": {
      "type": "string",
      "minLength": 36,
      "maxLength": 36
    },
    "contractSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "lastRunAt": {
      "type": ["string", "null"]
    },
    "paused": {
      "type": "boolean"
    },
    "pauseReason": {
      "type": ["string", "null"]
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "completedAt", "goalEvaluationAttempts", "lastGoalEvaluation"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["active", "completed"]
        },
        "completedAt": {
          "type": ["string", "null"]
        },
        "goalEvaluationAttempts": {
          "type": "integer",
          "minimum": 0
        },
        "lastGoalEvaluation": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "runId",
                "verdict",
                "artifact",
                "sha256",
                "basisSha256",
                "evaluatedAt"
              ],
              "properties": {
                "runId": { "type": "string", "minLength": 1 },
                "verdict": {
                  "type": "string",
                  "enum": ["pass", "fail", "blocked", "needs-human"]
                },
                "artifact": { "type": "string", "minLength": 1 },
                "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "basisSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "evaluatedAt": { "type": "string", "minLength": 20 }
              }
            }
          ]
        }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "retries"],
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["open", "in-progress", "passed", "failed", "blocked", "needs-human"]
          },
          "source": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "retries": {
            "type": "integer",
            "minimum": 0
          },
          "links": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "artifacts": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/artifactBinding"
            }
          },
          "lastResult": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["runId", "runArtifact", "runSha256", "verdict", "partDefinitionSha256", "evaluatorSha256"],
                "properties": {
                  "runId": { "type": "string", "minLength": 1 },
                  "runArtifact": { "type": "string", "minLength": 1 },
                  "runSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                  "verdict": { "type": "string", "enum": ["pass", "fail", "blocked", "needs-human"] },
                  "partDefinitionSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                  "evaluatorSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
                }
              }
            ]
          }
        }
      }
    },
    "partResolutions": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "partId",
          "fromStatus",
          "actor",
          "reason",
          "evidenceRunId",
          "evidenceRunArtifact",
          "evidenceRunSha256",
          "resolvedAt"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "partId": { "type": "string", "minLength": 1 },
          "fromStatus": { "type": "string", "enum": ["blocked", "needs-human"] },
          "actor": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 3 },
          "evidenceRunId": { "type": "string", "minLength": 1 },
          "evidenceRunArtifact": { "type": "string", "minLength": 1 },
          "evidenceRunSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "resolvedAt": { "type": "string", "minLength": 20 }
        }
      }
    },
    "goalResolutions": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "fromVerdict",
          "actor",
          "reason",
          "evidenceRunId",
          "evidenceRunArtifact",
          "evidenceRunSha256",
          "resolvedAt"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "fromVerdict": { "type": "string", "enum": ["blocked", "needs-human"] },
          "actor": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 3 },
          "evidenceRunId": { "type": "string", "minLength": 1 },
          "evidenceRunArtifact": { "type": "string", "minLength": 1 },
          "evidenceRunSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "resolvedAt": { "type": "string", "minLength": 20 }
        }
      }
    },
    "recordedRuns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["runId", "artifact", "sha256", "finishedAt", "status"],
        "properties": {
          "runId": { "type": "string", "minLength": 1 },
          "artifact": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "finishedAt": { "type": "string", "minLength": 20 },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "blocked", "needs-human", "no-work", "dry-run", "budget-exceeded"]
          }
        }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runsToday", "runtimeMinutesToday"],
      "properties": {
        "date": {
          "type": ["string", "null"],
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "runsToday": {
          "type": "integer",
          "minimum": 0
        },
        "runtimeMinutesToday": {
          "type": "number",
          "minimum": 0
        },
        "estimatedUsdToday": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "evolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currentStrategyVersion",
        "runsSincePromotion",
        "consecutiveFailures",
        "pendingExperiment",
        "observations",
        "history",
        "rollbackHistory"
      ],
      "properties": {
        "currentStrategyVersion": {
          "type": "integer",
          "minimum": 1
        },
        "currentStrategySha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "strategyArchives": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["version", "sha256"],
            "properties": {
              "version": { "type": "integer", "minimum": 1 },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          }
        },
        "runsSincePromotion": {
          "type": "integer",
          "minimum": 0
        },
        "consecutiveFailures": {
          "type": "integer",
          "minimum": 0
        },
        "runsSinceExperiment": {
          "type": "integer",
          "minimum": 0
        },
        "consecutiveFailuresSinceExperiment": {
          "type": "integer",
          "minimum": 0
        },
        "pendingExperiment": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["experimentId", "sha256", "baselineVersion", "candidateVersion", "stagedAt"],
              "properties": {
                "experimentId": { "type": "string" },
                "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "baselineVersion": { "type": "integer", "minimum": 1 },
                "candidateVersion": { "type": "integer", "minimum": 2 },
                "stagedAt": { "type": "string" }
              }
            }
          ]
        },
        "observations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["runId", "metric", "score"],
            "properties": {
              "runId": { "type": "string" },
              "metric": { "type": "string" },
              "score": { "type": "number" },
              "strategyVersion": { "type": "integer", "minimum": 1 },
              "strategySha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          }
        },
        "history": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["experimentId", "sha256", "outcome", "baselineVersion", "candidateVersion", "improvement"],
            "properties": {
              "experimentId": { "type": "string" },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "outcome": {
                "type": "string",
                "enum": ["promoted", "rejected", "pending-review", "invalidated", "abandoned"]
              },
              "baselineVersion": { "type": "integer", "minimum": 1 },
              "candidateVersion": { "type": "integer", "minimum": 2 },
              "improvement": { "type": "number" },
              "artifact": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 3 },
              "approval": {
                "type": "object",
                "additionalProperties": false,
                "required": ["artifact", "sha256", "approver", "approvedAt"],
                "properties": {
                  "artifact": { "type": "string", "minLength": 1 },
                  "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                  "approver": { "type": "string", "minLength": 1 },
                  "approvedAt": { "type": "string", "minLength": 20 }
                }
              },
              "decision": {
                "type": "object",
                "additionalProperties": false,
                "required": ["artifact", "sha256", "actor", "decidedAt", "reason"],
                "properties": {
                  "artifact": { "type": "string", "minLength": 1 },
                  "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                  "actor": { "type": "string", "minLength": 1 },
                  "decidedAt": { "type": "string", "minLength": 20 },
                  "reason": { "type": "string", "minLength": 3 }
                }
              }
            }
          }
        },
        "rollbackHistory": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["fromVersion", "restoredFromVersion", "newVersion", "actor", "reason", "at"],
            "properties": {
              "fromVersion": { "type": "integer", "minimum": 1 },
              "restoredFromVersion": { "type": "integer", "minimum": 1 },
              "newVersion": { "type": "integer", "minimum": 2 },
              "actor": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 3 },
              "at": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "artifactBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "reference", "sha256"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "reference": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}
