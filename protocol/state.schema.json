{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sheepxux/Loop-Engineering/v1.0.2/protocol/state.schema.json",
  "title": "Loop State",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "loop", "lastRunAt", "items", "budgets"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "loop-engineering/v1"
    },
    "loop": {
      "type": "string"
    },
    "generation": {
      "type": "string",
      "minLength": 36,
      "maxLength": 36
    },
    "contractSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "lastRunAt": {
      "type": ["string", "null"]
    },
    "paused": {
      "type": "boolean"
    },
    "pauseReason": {
      "type": ["string", "null"]
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "retries"],
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["open", "in-progress", "passed", "failed", "blocked", "needs-human"]
          },
          "source": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "retries": {
            "type": "integer",
            "minimum": 0
          },
          "links": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "recordedRuns": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["runId", "artifact", "sha256", "finishedAt", "status"],
        "properties": {
          "runId": { "type": "string", "minLength": 1 },
          "artifact": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "finishedAt": { "type": "string", "minLength": 20 },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "blocked", "needs-human", "no-work", "dry-run", "budget-exceeded"]
          }
        }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runsToday", "runtimeMinutesToday"],
      "properties": {
        "date": {
          "type": ["string", "null"],
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "runsToday": {
          "type": "integer",
          "minimum": 0
        },
        "runtimeMinutesToday": {
          "type": "number",
          "minimum": 0
        },
        "estimatedUsdToday": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "evolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currentStrategyVersion",
        "runsSincePromotion",
        "consecutiveFailures",
        "pendingExperiment",
        "observations",
        "history",
        "rollbackHistory"
      ],
      "properties": {
        "currentStrategyVersion": {
          "type": "integer",
          "minimum": 1
        },
        "currentStrategySha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "strategyArchives": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["version", "sha256"],
            "properties": {
              "version": { "type": "integer", "minimum": 1 },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          }
        },
        "runsSincePromotion": {
          "type": "integer",
          "minimum": 0
        },
        "consecutiveFailures": {
          "type": "integer",
          "minimum": 0
        },
        "runsSinceExperiment": {
          "type": "integer",
          "minimum": 0
        },
        "consecutiveFailuresSinceExperiment": {
          "type": "integer",
          "minimum": 0
        },
        "pendingExperiment": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["experimentId", "sha256", "baselineVersion", "candidateVersion", "stagedAt"],
              "properties": {
                "experimentId": { "type": "string" },
                "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "baselineVersion": { "type": "integer", "minimum": 1 },
                "candidateVersion": { "type": "integer", "minimum": 2 },
                "stagedAt": { "type": "string" }
              }
            }
          ]
        },
        "observations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["runId", "metric", "score"],
            "properties": {
              "runId": { "type": "string" },
              "metric": { "type": "string" },
              "score": { "type": "number" },
              "strategyVersion": { "type": "integer", "minimum": 1 },
              "strategySha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          }
        },
        "history": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["experimentId", "sha256", "outcome", "baselineVersion", "candidateVersion", "improvement"],
            "properties": {
              "experimentId": { "type": "string" },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "outcome": {
                "type": "string",
                "enum": ["promoted", "rejected", "pending-review", "invalidated", "abandoned"]
              },
              "baselineVersion": { "type": "integer", "minimum": 1 },
              "candidateVersion": { "type": "integer", "minimum": 2 },
              "improvement": { "type": "number" },
              "artifact": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 3 },
              "approval": {
                "type": "object",
                "additionalProperties": false,
                "required": ["artifact", "sha256", "approver", "approvedAt"],
                "properties": {
                  "artifact": { "type": "string", "minLength": 1 },
                  "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                  "approver": { "type": "string", "minLength": 1 },
                  "approvedAt": { "type": "string", "minLength": 20 }
                }
              },
              "decision": {
                "type": "object",
                "additionalProperties": false,
                "required": ["artifact", "sha256", "actor", "decidedAt", "reason"],
                "properties": {
                  "artifact": { "type": "string", "minLength": 1 },
                  "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                  "actor": { "type": "string", "minLength": 1 },
                  "decidedAt": { "type": "string", "minLength": 20 },
                  "reason": { "type": "string", "minLength": 3 }
                }
              }
            }
          }
        },
        "rollbackHistory": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["fromVersion", "restoredFromVersion", "newVersion", "actor", "reason", "at"],
            "properties": {
              "fromVersion": { "type": "integer", "minimum": 1 },
              "restoredFromVersion": { "type": "integer", "minimum": 1 },
              "newVersion": { "type": "integer", "minimum": 2 },
              "actor": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 3 },
              "at": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
