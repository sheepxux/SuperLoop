{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sheepxux/Loop-Engineering/v0.1.0/protocol/evaluator.schema.json",
  "title": "Evaluator Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "loop", "itemId", "verdict", "evidence", "reasons"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "loop-engineering/v1"
    },
    "loop": {
      "type": "string"
    },
    "itemId": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail", "blocked", "needs-human"]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "summary"],
        "properties": {
          "type": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "exitCode": {
            "type": ["integer", "null"]
          }
        }
      }
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "nextAction": {
      "type": "string",
      "enum": ["accept", "retry", "move-to-inbox", "ask-human"]
    }
  }
}
