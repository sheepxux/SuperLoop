{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sheepxux/Loop-Engineering/v0.3.0/protocol/experiment.schema.json",
  "title": "Strategy Evolution Experiment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "loop",
    "experimentId",
    "metric",
    "baseline",
    "candidate",
    "evidence",
    "recommendation"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "loop-engineering/v1"
    },
    "loop": {
      "type": "string"
    },
    "experimentId": {
      "type": "string",
      "minLength": 3
    },
    "metric": {
      "type": "string",
      "minLength": 2
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "score", "samples"],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "score": { "type": "number" },
        "samples": { "type": "integer", "minimum": 1 }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "score", "samples"],
      "properties": {
        "strategy": {
          "$ref": "strategy.schema.json"
        },
        "score": { "type": "number" },
        "samples": { "type": "integer", "minimum": 1 }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "exitCode", "summary"],
        "properties": {
          "command": { "type": "string", "minLength": 1 },
          "exitCode": { "type": "integer" },
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "recommendation": {
      "type": "string",
      "enum": ["promote", "reject", "needs-human"]
    }
  }
}
