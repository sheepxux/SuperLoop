{
  "name": "@sheepxux/loop-engineering",
  "version": "0.1.0",
  "description": "Portable Loop-Engineering protocol and tooling for AI coding agents.",
  "type": "module",
  "main": "./src/cli.js",
  "author": "sheepxux",
  "bin": {
    "loopctl": "bin/loopctl.js"
  },
  "files": [
    ".github/",
    "adapters/",
    "bin/",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "docs/",
    "examples/",
    "SECURITY.md",
    "protocol/",
    "scripts/",
    "src/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "build:adapters": "node ./scripts/build-adapters.js",
    "validate:examples": "node ./bin/loopctl.js validate examples/ci-triage/loop.yaml examples/dependency-update/loop.yaml examples/frontend-qa/loop.yaml",
    "doctor": "node ./bin/loopctl.js doctor",
    "smoke": "npm test && npm run validate:examples && npm run doctor && node ./bin/loopctl.js render codex examples/ci-triage/loop.yaml --out /tmp/loop-engineering-codex && node ./bin/loopctl.js render claude-code examples/ci-triage/loop.yaml --out /tmp/loop-engineering-claude"
  },
  "keywords": [
    "ai-agents",
    "loop-engineering",
    "codex",
    "claude-code",
    "automation",
    "protocol"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sheepxux/Loop-Engineering.git"
  },
  "bugs": {
    "url": "https://github.com/sheepxux/Loop-Engineering/issues"
  },
  "homepage": "https://github.com/sheepxux/Loop-Engineering#readme",
  "dependencies": {
    "ajv": "^8.17.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {}
}
